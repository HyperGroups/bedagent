{
  "name": "bedagent-audit",
  "version": "0.1.0",
  "description": "bedagent 提交时审计——扫描 git diff，检查 Agent 是否遵守铁律",
  "main": "dist/index.js",
  "bin": {
    "bedagent-audit": "dist/index.js"
  },
  "scripts": {
